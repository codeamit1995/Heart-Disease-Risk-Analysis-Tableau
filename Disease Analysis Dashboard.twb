            <column caption='Disease_Type' datatype='string' name='[Calculation_0036340348325902]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [HadDiabetes] = &quot;Yes&quot; THEN &quot;Diabetes&quot;&#13;&#10;ELSEIF [HadStroke] = &quot;Yes&quot; THEN &quot;Stroke&quot;&#13;&#10;ELSEIF [HadCOPD] = &quot;Yes&quot; THEN &quot;COPD&quot;&#13;&#10;ELSEIF [HadKidneyDisease] = &quot;Yes&quot; THEN &quot;Kidney Disease&quot;&#13;&#10;ELSEIF [HadAsthma] = &quot;Yes&quot; THEN &quot;Asthma&quot;&#13;&#10;ELSEIF [HadArthritis] = &quot;Yes&quot; THEN &quot;Arthritis&quot;&#13;&#10;ELSEIF [HadSkinCancer] = &quot;Yes&quot; THEN &quot;Skin Cancer&quot;&#13;&#10;ELSEIF [HadAngina] = &quot;Yes&quot; THEN &quot;Angina&quot;&#13;&#10;ELSEIF [HadDepressiveDisorder] = &quot;Yes&quot; THEN &quot;Depressive Disorder&quot;&#13;&#10;ELSE &quot;None&quot;&#13;&#10;END' />
            </column>
            <column caption='BMI Rounded' datatype='real' name='[Calculation_1802431240155142]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ROUND(AVG([BMI]),0)' />
            </column>
            <column caption='Sex Filter' datatype='boolean' name='[Calculation_1802431276793866]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[ColorEnd (copy)_1802431275552776] = &quot;All&quot; THEN TRUE&#13;&#10;ELSEIF [Sex] = [Parameters].[ColorEnd (copy)_1802431275552776] THEN TRUE&#13;&#10;ELSE FALSE&#13;&#10;END' />
            </column>
            <column caption='Had Angina' datatype='string' name='[HadAngina]' role='dimension' type='nominal' />
            <column caption='Had Arthritis' datatype='string' name='[HadArthritis]' role='dimension' type='nominal' />
